@page "/"
@using BookStore.Frontend.Dtos
@using BookStore.Frontend.Clients
@inject BookClient Clients

<PageTitle>My Book Store</PageTitle>

<h1>📚 My Book Store</h1>

@if (books is null){
    <p><em>Loading your books....</em></p>
}
else if (books.Length == 0){
    <p>No books found. Go add some!</p>
}
else{
    <table class="table table-striped table-bordered mt-4">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Author</th>
                <th>Price</th>
                <th>Release Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in books)
            {
                <tr>
                    <td>@book.Id</td>
                    <td>@book.Name</td>
                    <td>@book.Author</td>
                    <td>$@book.Price</td>
                    <td>@book.ReleaseDate.ToString("MMMM dd, yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code{
    private BookSummaryDto[]? books;

    protected override async Task OnInitializedAsync(){
        books = await Clients.GetBooksAsync();
    }
}
